# ── TERRAFORM ────────────────────────────────────────────────────────────────
# Provider binaries and cached modules — large, OS-specific, regenerated by init
**/.terraform/
# State files contain sensitive resource details — stored in Azure Blob instead
*.tfstate
*.tfstate.backup
# Plan files are environment-specific and may contain sensitive values
*.tfplan
tfplan*
crash.log
# Override files are for local temporary changes only
override.tf
override.tf.json
*_override.tf
*_override.tf.json
# Note: .terraform.lock.hcl SHOULD be committed (reproducible provider versions)

# ── SECRETS AND CREDENTIALS ───────────────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
.env
.env.*
!.env.example
secrets.yaml
*-secrets.yaml
*-secret.yaml
kubeconfig
*.kubeconfig
service-account*.json
# Azure credential files
azureauth.json
credentials.json

# ── KUBERNETES SENSITIVE FILES ────────────────────────────────────────────────
# Sealed secrets source — contains plaintext values before sealing
*-unsealed.yaml
# Never commit raw Secret manifests (use Key Vault + CSI driver instead)
kubernetes/secrets/

# ── IDE AND EDITOR ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ── OPERATING SYSTEM ─────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ── PYTHON ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
.venv/
venv/
ENV/
env/
.pytest_cache/
.coverage
htmlcov/

# ── NODE.JS ──────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity

# ── GO ───────────────────────────────────────────────────────────────────────
*.exe
*.exe~
*.dll
*.so
*.dylib
vendor/

# ── JAVA / MAVEN / GRADLE ────────────────────────────────────────────────────
target/
*.class
*.jar
*.war
*.ear
.gradle/
build/

# ── .NET / C# ────────────────────────────────────────────────────────────────
bin/
obj/
*.user
*.suo
*.userprefs
.vs/
packages/

# ── DOCKER ───────────────────────────────────────────────────────────────────
*.tar

# ── LOGS AND TEMP ─────────────────────────────────────────────────────────────
*.log
logs/
tmp/
temp/
*.tmp

# ── SECURITY SCAN OUTPUT ──────────────────────────────────────────────────────
# SARIF and scan reports are uploaded to GitHub Security tab, not committed
*.sarif
trivy-*.json
gitleaks-report.*
zap-report*
checkov-results*
tfsec-results*

# ── MISCELLANEOUS ─────────────────────────────────────────────────────────────
*.zip
*.tar.gz
*.tgz
*.bak
*.orig
